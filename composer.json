{
    "name": "graystackit/laravel-helpspace-api",
    "description": "Laravel package for the HelpSpace API, built on Saloon 4",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "helpspace", "support", "tickets", "saloon"],
    "homepage": "https://github.com/GraystackIT/laravel-helpspace-api",
    "authors": [
        {
            "name": "GraystackIT"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "GraystackIT\\HelpSpace\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GraystackIT\\HelpSpace\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GraystackIT\\HelpSpace\\HelpSpaceServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
